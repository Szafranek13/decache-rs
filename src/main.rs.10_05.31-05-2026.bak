///AI GENERATED TRANSLATION OF pHash.cpp CAUSE I GAVE UP WITH THIS AI SLOP SHIT
use image::imageops::FilterType;

const WIDTH: usize = 32;
const HEIGHT: usize = 32;

fn generate_hash(image_path: &str) -> u64 {
    let img = image::open(image_path)
        .expect("Cannot open image")
        .resize_exact(32, 32, FilterType::Triangle)
        .grayscale();

    let gray = img.to_luma8();

    let mut frame = [0u8; WIDTH * HEIGHT];
    frame.copy_from_slice(gray.as_raw());

    compute_phash(&frame)
}

fn compute_phash(frame: &[u8; 1024]) -> u64 {
    let mut dct = [[0.0f32; 8]; 8];

    let mut cos_x = [[0.0f32; 8]; 32];
    let mut cos_y = [[0.0f32; 8]; 32];

    for x in 0..32 {
        for u in 0..8 {
            cos_x[x][u] =
                (((2 * x + 1) as f32) * (u as f32) * std::f32::consts::PI / 64.0)
                    .cos();
        }
    }

    for y in 0..32 {
        for v in 0..8 {
            cos_y[y][v] =
                (((2 * y + 1) as f32) * (v as f32) * std::f32::consts::PI / 64.0)
                    .cos();
        }
    }

    for u in 0..8 {
        for v in 0..8 {
            let mut sum = 0.0f32;

            for x in 0..32 {
                for y in 0..32 {
                    let pixel = frame[y * 32 + x] as f32;

                    sum += pixel
                        * cos_x[x][u]
                        * cos_y[y][v];
                }
            }

            let cu = if u == 0 {
                1.0 / 2.0_f32.sqrt()
            } else {
                1.0
            };

            let cv = if v == 0 {
                1.0 / 2.0_f32.sqrt()
            } else {
                1.0
            };

            dct[u][v] = 0.25 * cu * cv * sum;
        }
    }

    let mut total = 0.0f32;

    for u in 0..8 {
        for v in 0..8 {
            total += dct[u][v];
        }
    }

    let avg = total / 64.0;

    let mut hash = 0u64;

    for u in 0..8 {
        for v in 0..8 {
            hash <<= 1;

            if dct[u][v] > avg {
                hash |= 1;
            }
        }
    }

    hash
}
///END OF AI GENERATED TRANSLATION OF pHash.cpp

fn compare_hash(first_hash: img_hash::ImageHash, second_hash: img_hash::ImageHash) {
    //compare two hashes
    let distance = first_hash.dist(&second_hash);
    println!("distance = {}", distance);
}

