//Constants and statics, mainly paths. LazyLock is a saviour <3

static BASE_DIR: LazyLock<PathBuf> = LazyLock::new(|| {
    let path = PathBuf::from("./");
    if !path.is_dir() {
        panic!("Cannot read base dir!: {}", path.display());
    }

    path
});

static DATA_DIR: LazyLock<PathBuf> = LazyLock::new(|| {
    let path = BASE_DIR.join("data");
    if !path.is_dir() {
        panic!("Cannot read data dir!: {}", path.display());
    }

    path
});

static FIREFOX_PROFILE_DIR: LazyLock<PathBuf> = LazyLock::new(|| {
    home_dir()
        .expect("Cannot read $HOME")
        .join(".mozilla")
        .join("firefox")
});

static LIBREWOLF_PROFILE_DIR: LazyLock<PathBuf> = LazyLock::new(|| {
